<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <RootNamespace>ImperiumEngine</RootNamespace>
        <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    </PropertyGroup>

    <ItemGroup>
      <PackageReference Include="Hexa.NET.ImGui" Version="2.2.10-prerelease" />
      <PackageReference Include="Silk.NET" Version="2.23.0" />
      <PackageReference Include="Slang.Sdk" Version="0.5.1" />
    </ItemGroup>

    <ItemGroup>
      <ProjectReference Include="..\Core\Core.csproj" />
    </ItemGroup>

    <ItemGroup>
      <None Include="Content\**\*" Exclude="Content\**\*.cs">
        <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        <Link>Content\%(RecursiveDir)%(Filename)%(Extension)</Link>
      </None>
    </ItemGroup>

    <ItemGroup>
      <Folder Include="_Content\3D\" />
      <Folder Include="_Content\Audio\" />
      <Folder Include="Objects\Components\" />
      <Folder Include="_Resources\icons_enum\" />
      <Folder Include="_Resources\thumbnails\" />
    </ItemGroup>

</Project>
